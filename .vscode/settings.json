{
    "json.schemas": [

        {
            "fileMatch": [
                "/**itemDef.jsonc"
            ],
            "url": "./Schemas/itemDefSchema.json"
        },
        {
            "fileMatch": [
                "/**nodeDef.jsonc"
            ],
            "url": "./Schemas/nodeDefSchema.json"
        },
        {
            "fileMatch": [
                "/**enemyDef.jsonc"
            ],
            "url": "./Schemas/enemyDefSchema.json"
        },
        {
            "fileMatch": [
                "/**map-nodes.jsonc"
            ],
            "url": "./Schemas/map-nodesSchema.json"
        }
    ],
    "workbench.tree.indent": 10,
    "workbench.view.showQuietly": {
        "workbench.panel.output": true
    },
    "workbench.editor.dragToOpenWindow": false,
    "workbench.editor.tabSizing": "fit",
    "editor.showFoldingControls": "always",
    "editor.defaultFoldingRangeProvider": "zokugun.explicit-folding",
    "[javascript]": {
        "explicitFolding.rules": [
            {
                "begin": "{",
                "end": "}",
                "while": "content",
                "foldLastLine": true 
            }
        ]
    }
}