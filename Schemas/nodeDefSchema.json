{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Game Node Schema",
    "description": "Strict schema for game nodes with category-specific validation.",
    "type": "array",
    "items": {
        "type": "object",
        "required": ["id", "name", "desc", "img", "category", "subcategory", "drops", "rarity"],
        "properties": {
            "id": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
            },
            "name": {
                "type": "string"
            },
            "desc": { 
                "type": "string"
            },
            "img": {
                "type": ["string", "null"],
                "default": null
            },
            "notes": {
                "type": "string"
            },
            "category": {
                "type": "string",
                "enum": ["Ore", "Trees", "Plants", "Other"]
            },
            "subcategory": {
                "type": "string",
                "enum": ["determinSubCategory", "Food", "NotFood"]
            },
            "health":{
                "type": ["integer", "string"]
            },
            "tool":{
                "type": "string",
                "enum": ["pick", "axe", "sword", "hand"]
            },
            "drops": {
                "type": "object",
                "properties": {
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "id": {
                                    "type": "string",
                                    "pattern": "^[a-z0-9_]+$"
                                },
                                "amount": {
                                    "type": "string"
                                }
                            },
                            "required": ["id", "amount"]
                        }
                    },
                    "xp": {
                        "type": ["integer", "string"]
                    }
                },
                "required": ["items"]
            },

            "rarity":{
                "type": "string",
                "enum": ["Common", "Rare", "Extremely Rare"]
            }
        },
        "allOf": [
            {
                "if": {
                    "required": ["tool"]
                },
                "then": {
                    "required": ["health"]
                }
            }
        ],
        "additionalProperties": false
    }
}